# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary, built with `go test -c`
*.test

# Output of the go coverage tool, specifically when used with LiteIDE
*.out

# Local agent scratch files. Durable agent docs are tracked explicitly.
.agents/*
!.agents/PLAN.md
!.agents/ROADMAP.md
!.agents/ROADMAP.zh.md
.sisyphus/

